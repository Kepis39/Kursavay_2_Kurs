<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.CopiesView"
             x:DataType="vm:CopiesViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="📦 Copies" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

    <Border Grid.Row="1" Background="#252536" CornerRadius="12" Padding="15" Margin="0,0,0,15">
      <Grid ColumnDefinitions="*,*,*,*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Inventory #" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="BookId" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="ThemeCode" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="3" Text="CopyCount" Foreground="#8888AA" Margin="5,0"/>

        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewInventoryNumber}" Watermark="Inv#" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewBookId}" Watermark="BookId" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NewThemeCode}" Watermark="Theme" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding NewCopyCount}" Watermark="Count" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" VerticalAlignment="Center" Margin="10,0,0,0">
          <Button Content="➕ Add" Command="{Binding AddCommand}" Background="#007ACC" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
          <Button Content="💾 Update" Command="{Binding UpdateCommand}" Background="#4CAF50" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
          <Button Content="🗑️ Delete" Command="{Binding DeleteCommand}" Background="#F44336" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Background="#252536" CornerRadius="12" Padding="10">
      <DataGrid ItemsSource="{Binding Copies}" 
                SelectedItem="{Binding SelectedCopy}"
                AutoGenerateColumns="False"
                GridLinesVisibility="Horizontal"
                Background="Transparent"
                Foreground="White">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Inventory #" Binding="{Binding InventoryNumber}" Width="120"/>
          <DataGridTextColumn Header="BookId" Binding="{Binding BookId}" Width="100"/>
          <DataGridTextColumn Header="ThemeCode" Binding="{Binding ThemeCode}" Width="100"/>
          <DataGridTextColumn Header="CopyCount" Binding="{Binding CopyCount}" Width="100"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="3" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Status}" Foreground="#8888AA" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Content="📂 Import CSV" Command="{Binding ImportCsvCommand}" Background="#444466" Foreground="White" Padding="10,5" CornerRadius="6"/>
        <Button Content="📄 Import JSON" Command="{Binding ImportJsonCommand}" Background="#444466" Foreground="White" Padding="10,5" CornerRadius="6"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
