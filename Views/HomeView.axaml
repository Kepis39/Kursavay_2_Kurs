<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.HomeView"
             x:DataType="vm:HomeViewModel">
  <Grid Margin="30">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
      <TextBlock Text="📚" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,20"/>
      <TextBlock Text="{Binding WelcomeText}" 
                 FontSize="32" FontWeight="Bold" 
                 Foreground="White" HorizontalAlignment="Center"/>
      <TextBlock Text="Library Management System v1.0" 
                 FontSize="16" Foreground="#8888AA" 
                 HorizontalAlignment="Center" Margin="0,10,0,0"/>
      <TextBlock Text="SQLite + Avalonia 12 + Entity Framework" 
                 FontSize="14" Foreground="#666688" 
                 HorizontalAlignment="Center" Margin="0,5"/>
    </StackPanel>
  </Grid>
</UserControl>
