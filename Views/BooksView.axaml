<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.BooksView"
             x:DataType="vm:BooksViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="📖 Books" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

    <Border Grid.Row="1" Background="#252536" CornerRadius="12" Padding="15" Margin="0,0,0,15">
      <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,Auto" RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="BookId" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="Title" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Author" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="3" Text="Publisher" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="4" Text="Place" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="5" Text="Year" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="6" Text="Pages" Foreground="#8888AA" Margin="5,0"/>
        <TextBlock Grid.Row="0" Grid.Column="7" Text="Price" Foreground="#8888AA" Margin="5,0"/>

        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewBookId}" Watermark="ID" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewTitle}" Watermark="Title" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NewAuthor}" Watermark="Author" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding NewPublisher}" Watermark="Publisher" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding NewPlace}" Watermark="Place" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding NewYear}" Watermark="Year" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding NewPages}" Watermark="Pages" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <TextBox Grid.Row="1" Grid.Column="7" Text="{Binding NewPrice}" Watermark="Price" Margin="5" Background="#1E1E2E" Foreground="White" BorderBrush="#444466"/>
        <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="8" VerticalAlignment="Center" Margin="10,0,0,0">
          <Button Content="➕ Add" Command="{Binding AddCommand}" Background="#007ACC" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
          <Button Content="💾 Update" Command="{Binding UpdateCommand}" Background="#4CAF50" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
          <Button Content="🗑️ Delete" Command="{Binding DeleteCommand}" Background="#F44336" Foreground="White" Padding="12,6" CornerRadius="6" Margin="0,2"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Background="#252536" CornerRadius="12" Padding="10">
      <DataGrid ItemsSource="{Binding Books}" 
                SelectedItem="{Binding SelectedBook}"
                AutoGenerateColumns="False"
                GridLinesVisibility="Horizontal"
                Background="Transparent"
                Foreground="White">
        <DataGrid.Columns>
          <DataGridTextColumn Header="BookId" Binding="{Binding BookId}" Width="80"/>
          <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
          <DataGridTextColumn Header="Author" Binding="{Binding FirstAuthor}" Width="150"/>
          <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="120"/>
          <DataGridTextColumn Header="Place" Binding="{Binding PlaceOfPublication}" Width="120"/>
          <DataGridTextColumn Header="Year" Binding="{Binding YearOfPublication}" Width="70"/>
          <DataGridTextColumn Header="Pages" Binding="{Binding PageCount}" Width="70"/>
          <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="3" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Status}" Foreground="#8888AA" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Content="📂 Import CSV" Command="{Binding ImportCsvCommand}" Background="#444466" Foreground="White" Padding="10,5" CornerRadius="6"/>
        <Button Content="📊 Import Excel" Command="{Binding ImportExcelCommand}" Background="#444466" Foreground="White" Padding="10,5" CornerRadius="6"/>
        <Button Content="📄 Import JSON" Command="{Binding ImportJsonCommand}" Background="#444466" Foreground="White" Padding="10,5" CornerRadius="6"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
