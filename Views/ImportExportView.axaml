<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.ImportExportView"
             x:DataType="vm:ImportExportViewModel">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="🔄 Import / Export" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
      <Button Content="📥 Import JSON (All Tables)" Command="{Binding ImportJsonAllCommand}" Background="#007ACC" Foreground="White" Padding="12,8" CornerRadius="8" Margin="0,0,8,0"/>
      <Button Content="📥 Import XML (All Tables)" Command="{Binding ImportXmlAllCommand}" Background="#007ACC" Foreground="White" Padding="12,8" CornerRadius="8" Margin="0,0,8,0"/>
      <Button Content="📤 Export JSON (All Tables)" Command="{Binding ExportJsonAllCommand}" Background="#4CAF50" Foreground="White" Padding="12,8" CornerRadius="8"/>
    </WrapPanel>

    <Border Grid.Row="2" Background="#252536" CornerRadius="12" Padding="15">
      <ScrollViewer>
        <StackPanel Spacing="10">
          <TextBlock Text="Current Data Snapshot" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

          <TextBlock Text="Books" Foreground="#007ACC" FontWeight="Bold" FontSize="14"/>
          <DataGrid ItemsSource="{Binding Books}" AutoGenerateColumns="False" GridLinesVisibility="Horizontal" Background="Transparent" Foreground="White" Height="150">
            <DataGrid.Columns>
              <DataGridTextColumn Header="BookId" Binding="{Binding BookId}" Width="80"/>
              <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
              <DataGridTextColumn Header="Author" Binding="{Binding FirstAuthor}" Width="150"/>
            </DataGrid.Columns>
          </DataGrid>

          <TextBlock Text="Readers" Foreground="#007ACC" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
          <DataGrid ItemsSource="{Binding Readers}" AutoGenerateColumns="False" GridLinesVisibility="Horizontal" Background="Transparent" Foreground="White" Height="150">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Ticket" Binding="{Binding TicketNumber}" Width="80"/>
              <DataGridTextColumn Header="FullName" Binding="{Binding FullName}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <TextBlock Text="Copies" Foreground="#007ACC" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
          <DataGrid ItemsSource="{Binding Copies}" AutoGenerateColumns="False" GridLinesVisibility="Horizontal" Background="Transparent" Foreground="White" Height="150">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Inv#" Binding="{Binding InventoryNumber}" Width="100"/>
              <DataGridTextColumn Header="BookId" Binding="{Binding BookId}" Width="100"/>
            </DataGrid.Columns>
          </DataGrid>

          <TextBlock Text="Issues (Loans)" Foreground="#007ACC" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
          <DataGrid ItemsSource="{Binding Issues}" AutoGenerateColumns="False" GridLinesVisibility="Horizontal" Background="Transparent" Foreground="White" Height="150">
            <DataGrid.Columns>
              <DataGridTextColumn Header="IssueId" Binding="{Binding IssueId}" Width="80"/>
              <DataGridTextColumn Header="Ticket" Binding="{Binding TicketNumber}" Width="80"/>
              <DataGridTextColumn Header="Inv#" Binding="{Binding InventoryNumber}" Width="100"/>
              <DataGridTextColumn Header="IssueDate" Binding="{Binding IssueDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120"/>
              <DataGridTextColumn Header="ReturnDate" Binding="{Binding ReturnDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <TextBlock Grid.Row="3" Text="{Binding Status}" Foreground="#8888AA" Margin="0,10,0,0"/>
  </Grid>
</UserControl>
